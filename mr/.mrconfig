[DEFAULT]
git_gc = git gc "$@"
jobs = 1

include = cat $HOME/.config/mr/config.d/*

[$HOME/.dotfiles]
checkout = git clone https://github.com/tommoyer/dotfiles.git ${HOME}/.dotfiles
order = 1

[$HOME/Repos/tommoyer/ansible]
checkout = git clone https://github.com/tommoyer/ansible.git ${HOME}/Repos/tommoyer/ansible

