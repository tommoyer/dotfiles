[Desktop Entry]
Type=Application
Name=appimaged
Exec=/home/tmoyer/Applications/appimaged-806-x86_64.AppImage wrap "/home/tmoyer/Applications/appimaged-806-x86_64.AppImage"
Comment=/home/tmoyer/Applications/appimaged-806-x86_64.AppImage
Icon=/home/tmoyer/.cache/thumbnails/normal/008ae49071c9b757db664480cc793b98.png
Categories=Utility;
Terminal=true
NoDisplay=true
X-AppImage-Version=806
X-ExecLocation=/home/tmoyer/Applications/appimaged-806-x86_64.AppImage
TryExec=/home/tmoyer/Applications/appimaged-806-x86_64.AppImage
X-AppImage-Identifier=008ae49071c9b757db664480cc793b98
X-AppImage-UpdateInformation="gh-releases-zsync|probonopd|go-appimage|continuous|appimaged-*-x86_64.AppImage.zsync"
Actions=Trash;OpenPortableHome;CreatePortableHome;Extract;Update;Show

[Desktop Action Trash]
Name=Move to Trash
Exec=gio trash "/home/tmoyer/Applications/appimaged-806-x86_64.AppImage"

[Desktop Action OpenPortableHome]
Name=Open Portable Home in File Manager
Exec=xdg-open "/home/tmoyer/Applications/appimaged-806-x86_64.AppImage.home"

[Desktop Action CreatePortableHome]
Name=Create Portable Home
Exec=mkdir -p "/home/tmoyer/Applications/appimaged-806-x86_64.AppImage.home"

[Desktop Action Extract]
Name=Extract to AppDir
Exec=bash -c "cd '/home/tmoyer/Applications' && '/home/tmoyer/Applications/appimaged-806-x86_64.AppImage' --appimage-extract && xdg-open '/home/tmoyer/Applications/squashfs-root'"

[Desktop Action Update]
Name=Update
Exec=/home/tmoyer/Applications/appimaged-806-x86_64.AppImage update "/home/tmoyer/Applications/appimaged-806-x86_64.AppImage"

[Desktop Action Show]
Name=Open Containing Folder
Exec=xdg-open "/home/tmoyer/Applications"
